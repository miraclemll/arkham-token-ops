# Arkham API Key（必须）
# 在 https://intel.arkm.com/settings 生成
ARKHAM_API_KEY=your_arkham_api_key_here

# 目标代币配置（原始 monitor.py 脚本使用）
TARGET_TOKEN_ADDRESS=0xYOUR_TOKEN_ADDRESS
TARGET_CHAIN=ethereum
TARGET_TOKEN_NAME=Target Token
TARGET_TOKEN_QUERY=Target Token

# Telegram Bot 推送配置（必须）
# 找 @BotFather 获取 Bot Token
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Telegram Chat ID（用户数字 ID 或 群组/频道 ID）
# curl https://api.telegram.org/bot<TOKEN>/getUpdates 获取
TELEGRAM_CHAT_ID=your_chat_id
